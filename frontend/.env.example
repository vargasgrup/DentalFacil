# Local development (browser talks to backend directly):
NEXT_PUBLIC_API_URL=http://localhost:8001

# Railway / Docker Compose (recommended):
# Leave NEXT_PUBLIC_API_URL empty so the browser uses relative "/api/..." paths.
# Next.js rewrites proxy to BACKEND_URL (server-side).
# NEXT_PUBLIC_API_URL=
# BACKEND_URL=http://backend.railway.internal:${{Backend.PORT}}
#
# Alternative (direct, no proxy): set the public backend URL at *build* time:
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
