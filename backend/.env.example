# --- Database ---
# Local Docker Compose:
DATABASE_URL=postgresql+psycopg://dentalsimple:dentalsimple@localhost:5434/dentalsimple

# Railway: link the Postgres plugin and use reference variables, e.g.:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# (postgres:// is auto-normalized to postgresql+psycopg://)

# --- JWT ---
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Rate limiting (auth) ---
# Max requests per IP per minute for sensitive endpoints
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_SETUP_PER_MINUTE=3

# --- App ---
APP_NAME=M&D Odontología Especializada
# JSON array or a single URL / comma-separated (Railway-friendly):
CORS_ORIGINS=https://your-frontend.up.railway.app
# CORS_ORIGINS=["http://localhost:3001"]
CLINIC_NAME=M&D Odontología Especializada
CLINIC_PHONE=
CLINIC_ADDRESS=
CLINIC_RUC=
CLINIC_EMAIL=
CLINIC_TICKET_SERIE=T001
PUBLIC_APP_URL=http://localhost:3001

# --- Reminder scheduler ---
REMINDER_HOURS_BEFORE=24

# --- Optional persistence paths (Railway Volume) ---
# TOOTH_MEDIA_ROOT=/app/uploads/tooth_media
