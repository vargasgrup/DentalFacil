# --- Database ---
# Default local / Tauri / 3-PC install (no Docker, no Postgres daemon):
DATABASE_URL=sqlite:///./data/clinica.db

# Railway staging (persist Volume mounted at /data):
# DATABASE_URL=sqlite:////data/clinica.db
# SOURCE_DATABASE_URL=${{Postgres.DATABASE_URL}}   # only during one-shot cutover
# then: python -m scripts.railway_sqlite_cutover
# See docs/RAILWAY.md

# Optional PostgreSQL (legacy only — this build expects UUID; use ETL, do not keep int PKs):
# DATABASE_URL=postgresql+psycopg://dentalsimple:dentalsimple@localhost:5434/dentalsimple

# Cutover local PG → SQLite UUID:
#   SOURCE_DATABASE_URL=postgresql+psycopg://... TARGET_DATABASE_URL=sqlite:///./data/clinica.db
#   python -m scripts.pg_to_sqlite_uuid

# --- JWT ---
# Generar valor único por entorno (NO uses el default del código en producción):
#   openssl rand -hex 32
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
# APP_ENV=development
# En producción: APP_ENV=production y JWT_SECRET con ≥32 caracteres aleatorios.
# ACCESS_TOKEN_EXPIRE_MINUTES=720
# REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Rate limiting (auth) ---
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_SETUP_PER_MINUTE=3

# --- App ---
APP_NAME=M&D Odontología Especializada
CORS_ORIGINS=["http://localhost:3001"]
CLINIC_NAME=M&D Odontología Especializada
CLINIC_PHONE=
CLINIC_ADDRESS=
CLINIC_RUC=
CLINIC_EMAIL=
CLINIC_TICKET_SERIE=T001
PUBLIC_APP_URL=http://localhost:3001

# --- Reminder scheduler ---
REMINDER_HOURS_BEFORE=24

# --- WhatsApp Cloud API (Meta Graph) — opcional ---
# Sin estas variables, el envío usa Web Share API / descarga + wa.me (fallback nativo).
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_API_VERSION=v17.0
# WHATSAPP_REQUEST_TIMEOUT_SECONDS=30
# PDF_CACHE_MAX_SIZE=50
# MAX_RETRY_ATTEMPTS=3

# --- Optional persistence paths ---
# TOOTH_MEDIA_ROOT=./data/tooth_media
# COMPLEMENTARY_TESTS_ROOT=./data/complementary_tests
