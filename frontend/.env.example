# Local development (browser → backend directly):
NEXT_PUBLIC_API_URL=http://localhost:8001

# Railway (recommended):
# Leave NEXT_PUBLIC_API_URL empty (or unset). The browser calls same-origin /api/...
# and Next.js proxies to BACKEND_URL at runtime (no rebuild when backend URL changes).
# NEXT_PUBLIC_API_URL=
# BACKEND_URL=https://your-backend.up.railway.app
#
# Alternative: browser → backend directly (requires CORS_ORIGINS on backend):
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
